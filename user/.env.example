# Backend API URL (required for production — set in Netlify Environment Variables)
# Local: http://localhost:5000
# Production: https://your-api-name.onrender.com
REACT_APP_API_URL=http://localhost:5000

# Optional — translation uses MyMemory API by default without a key
REACT_APP_GOOGLE_TRANSLATE_API_KEY=your_api_key_here

# Faster builds; fewer third-party source map warnings
GENERATE_SOURCEMAP=false
