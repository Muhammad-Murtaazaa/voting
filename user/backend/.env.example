# ─── Render production (Node backend: voting-4sb6.onrender.com) ─────────────
NODE_ENV=production
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ivotepk?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
ENCRYPTION_KEY=your_32_character_encryption_key

CLIENT_URL=https://ivotepk.netlify.app
RP_ID=ivotepk.netlify.app
AI_FRAUD_API=https://voting-1-k5b9.onrender.com

# ─── Brevo email (recommended for Render) ───────────────────────────────────
# On Render: use the API key (tab "API keys & MCP") — NOT SMTP (port 587 blocked).
# BREVO_API_KEY=xkeysib-your_api_key_from_brevo
# BREVO_FROM_EMAIL=your_verified_sender@email.com

# Local dev only — Brevo SMTP (from Brevo → SMTP & API → SMTP tab):
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=b0167b001@smtp-brevo.com
# BREVO_SMTP_KEY=your_generated_smtp_key
# BREVO_FROM_EMAIL=your_verified_sender@email.com

FROM_NAME=iVotePK

# Optional: SendGrid instead of Gmail
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional: support chatbot
CHATBOT_PROVIDER=gemini
GEMINI_API_KEY=

# ─── Local development ───────────────────────────────────────────────────────
# PORT=5000
# NODE_ENV=development
# CLIENT_URL=http://localhost:3000
# RP_ID=localhost
# AI_FRAUD_API=http://localhost:5001
