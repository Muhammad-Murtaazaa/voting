# Node.js backend — copy to .env and fill in values

PORT=5000
NODE_ENV=development

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ivotepk?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
ENCRYPTION_KEY=your_32_character_encryption_key

CLIENT_URL=http://localhost:3000
RP_ID=localhost

# Python AI fraud service (local or Render URL, no trailing slash)
AI_FRAUD_API=http://localhost:5001

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=iVotePK

# Optional: SendGrid instead of Gmail
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional: support chatbot
CHATBOT_PROVIDER=gemini
GEMINI_API_KEY=
